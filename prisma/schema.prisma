datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum AdminRole {
  SUPER_ADMIN
  VIEWER
}

model Organization {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  createdAt       DateTime         @default(now())
  admins          AdminUser[]
  assessmentLinks AssessmentLink[]
  assessments     Assessment[]
}

model AdminUser {
  id                       String           @id @default(cuid())
  organizationId           String
  name                     String
  email                    String           @unique
  passwordHash             String
  role                     AdminRole        @default(SUPER_ADMIN)
  sessionVersion           Int              @default(1)
  isActive                 Boolean          @default(true)
  lastLoginAt              DateTime?
  createdAt                DateTime         @default(now())

  organization             Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedReportRevisions  ReportRevision[] @relation("ReportRevisionUploadedBy")
  validatedReportRevisions ReportRevision[] @relation("ReportRevisionValidatedBy")
  validatedAssessmentResults AssessmentResult[] @relation("AssessmentResultValidatedBy")
}

model AssessmentLink {
  id             String       @id @default(cuid())
  organizationId String
  token          String       @unique
  label          String
  requestedRole  String
  assessmentType String       @default("zpi_hr")
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assessments    Assessment[]
}

model Assessment {
  id               String            @id @default(cuid())
  organizationId   String
  assessmentLinkId String
  assessmentType   String            @default("zpi_hr")
  respondentName   String
  respondentEmail  String?
  age              Int?
  candidateCompany String?
  requestedRole    String
  createdAt        DateTime          @default(now())

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assessmentLink   AssessmentLink    @relation(fields: [assessmentLinkId], references: [id], onDelete: Cascade)
  result           AssessmentResult?
}

model AssessmentResult {
  id                        String     @id @default(cuid())
  assessmentId              String     @unique

  avgScore                  Int
  avgRange                  String
  orientation               String
  roleComment               String

  reliabilityScore          Int?
  reliabilityLabel          String?

  traitsJson                Json
  answersJson               Json?
  expandedReportJson        Json?
  expandedReportGeneratedAt DateTime?

  isGenerating              Boolean          @default(false)
  generationError           String?

  isValidated               Boolean          @default(false)
  validatedAt               DateTime?
  validatedById             String?
  validatedRevisionId       String?

  createdAt                 DateTime         @default(now())

  assessment                Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  validatedBy               AdminUser?       @relation("AssessmentResultValidatedBy", fields: [validatedById], references: [id], onDelete: SetNull)
  reportRevisions           ReportRevision[]
}

model ReportRevision {
  id                 String           @id @default(cuid())
  assessmentResultId String
  uploadedById       String
  originalFileName   String
  mimeType           String
  fileBytes          Bytes
  fileSize           Int
  status             String           @default("VALIDATED")
  createdAt          DateTime         @default(now())
  validatedAt        DateTime?
  validatedById      String?

  assessmentResult   AssessmentResult @relation(fields: [assessmentResultId], references: [id], onDelete: Cascade)
  uploadedBy         AdminUser        @relation("ReportRevisionUploadedBy", fields: [uploadedById], references: [id], onDelete: Cascade)
  validatedBy        AdminUser?       @relation("ReportRevisionValidatedBy", fields: [validatedById], references: [id], onDelete: SetNull)
}
