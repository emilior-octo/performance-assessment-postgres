<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <title>Dettaglio ZPI™ – Zenith Performance Index</title>

  <style>
    body { font-family: Arial, sans-serif; max-width: 1000px; margin: 40px auto; padding: 0 16px; }
    .card { border: 1px solid #ddd; border-radius: 12px; padding: 20px; margin-bottom: 20px; }
    .grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
    .trait { border: 1px solid #eee; border-radius: 10px; padding: 16px; }
    .muted { color: #666; }
    .topbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; gap: 16px; }
    .actions { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }

    .btn {
      display: inline-block;
      padding: 10px 14px;
      border: 0;
      border-radius: 8px;
      cursor: pointer;
      text-decoration: none;
      background: #111;
      color: #fff;
      font-size: 14px;
      line-height: 1.2;
    }

    .btn-secondary {
      background: #f5f5f5;
      color: #111;
      border: 1px solid #ddd;
    }

    .notice {
      padding: 14px 16px;
      margin: 16px 0 24px;
      border-radius: 10px;
      line-height: 1.45;
    }

    .notice-warning {
      background: #fff7ed;
      border: 1px solid #fed7aa;
      color: #9a3412;
    }

    .notice-success {
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      color: #166534;
    }

    .notice-error {
      background: #fee2e2;
      border: 1px solid #fecaca;
      color: #991b1b;
    }

    .notice strong {
      display: block;
      margin-bottom: 4px;
    }

    .histogram {
      margin: 18px 0 24px;
      padding: 18px;
      border: 1px solid #eee;
      border-radius: 12px;
      background: #fafafa;
    }

    .histogram-title {
      margin: 0 0 6px;
      font-size: 18px;
    }

    .histogram-help {
      margin: 0 0 16px;
      font-size: 13px;
      color: #666;
    }

    .histogram-scale {
      display: grid;
      grid-template-columns: 120px 1fr 44px;
      gap: 12px;
      align-items: center;
      margin-bottom: 8px;
      font-size: 12px;
      color: #777;
    }

    .histogram-scale-line {
      position: relative;
      height: 18px;
      border-bottom: 1px solid #ddd;
    }

    .histogram-scale-line::before {
      content: "";
      position: absolute;
      left: 50%;
      top: 0;
      bottom: -1px;
      width: 1px;
      background: #aaa;
    }

    .histogram-scale-labels {
      display: flex;
      justify-content: space-between;
    }

    .histogram-row {
      display: grid;
      grid-template-columns: 120px 1fr 44px;
      gap: 12px;
      align-items: center;
      margin: 12px 0;
    }

    .histogram-name {
      font-size: 14px;
      font-weight: 700;
    }

    .histogram-track {
      position: relative;
      height: 22px;
      background: #f1f1f1;
      border-radius: 999px;
      overflow: hidden;
      border: 1px solid #e5e5e5;
    }

    .histogram-track::before {
      content: "";
      position: absolute;
      left: 50%;
      top: 0;
      bottom: 0;
      width: 1px;
      background: #999;
      z-index: 2;
    }

    .histogram-bar {
      position: absolute;
      top: 3px;
      height: 14px;
      border-radius: 999px;
    }

    .histogram-bar-positive {
      left: 50%;
      background: #111;
    }

    .histogram-bar-negative {
      right: 50%;
      background: #999;
    }

    .histogram-score {
      font-size: 14px;
      font-weight: 700;
      text-align: right;
    }

    .answers-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 12px;
      font-size: 14px;
    }

    .answers-table th,
    .answers-table td {
      border: 1px solid #e5e5e5;
      padding: 10px;
      text-align: left;
      vertical-align: top;
    }

    .answers-table th {
      background: #f7f7f7;
    }

    form { margin: 0; }

    @media (max-width: 700px) {
      .topbar {
        align-items: flex-start;
        flex-direction: column;
      }

      .grid {
        grid-template-columns: 1fr;
      }

      .histogram-scale,
      .histogram-row {
        grid-template-columns: 1fr;
        gap: 6px;
      }

      .histogram-score {
        text-align: left;
      }

      .histogram-name {
        font-size: 13px;
      }

      .answers-table {
        font-size: 13px;
      }
    }
  </style>

  <% if (isGenerating) { %>
    <meta http-equiv="refresh" content="8">
  <% } %>
</head>

<body>
  <div class="topbar">
    <p><a href="/admin">← Torna alla lista</a></p>

    <div class="actions">
      <a class="btn btn-secondary" href="/admin/<%= submission.id %>/pdf" target="_blank">
        Apri PDF
      </a>

      <% if (!isGenerating) { %>
        <% if (submission.analysis.expandedReport) { %>
          <form method="POST" action="/admin/<%= submission.id %>/regenerate-expanded-report" id="regenerate-expanded-form">
            <button class="btn" type="submit" id="regenerate-expanded-button" onclick="return confirm('Rigenerare la relazione AI? La relazione attuale verrà sostituita.');">
              Rigenera relazione AI
            </button>
          </form>
        <% } else { %>
          <form method="POST" action="/admin/<%= submission.id %>/generate-expanded-report" id="generate-expanded-form">
            <button class="btn" type="submit" id="generate-expanded-button">
              Genera relazione AI
            </button>
          </form>
        <% } %>

        <form method="POST" action="/admin/<%= submission.id %>/duplicate-test">
          <button class="btn btn-secondary" type="submit">
            Duplica test veloce
          </button>
        </form>

        <form method="POST" action="/admin/<%= submission.id %>/duplicate-test">
          <input type="hidden" name="generateAi" value="yes">
          <button class="btn btn-secondary" type="submit">
            Duplica + rigenera relazione
          </button>
        </form>
      <% } %>
    </div>
  </div>

  <% if (isGenerating) { %>
    <div class="notice notice-warning">
      <strong>Relazione in generazione.</strong>
      Il report esploso è in preparazione. La pagina si aggiornerà automaticamente.
    </div>
  <% } %>

  <% if (submission.analysis.generationError) { %>
    <div class="notice notice-error">
      <strong>Generazione non completata.</strong>
      <%= submission.analysis.generationError %>. Puoi rilanciare la generazione dal pulsante fallback.
    </div>
  <% } %>

  <% if (submission.analysis.expandedReport) { %>
    <div class="card">
      <h2>Relazione generale</h2>
      <p><%= submission.analysis.expandedReport.generalSummary || "-" %></p>
      <% if (submission.analysis.summary.roleFit && submission.analysis.summary.roleFit.score !== undefined) { %>
        <p><strong>Compatibilità con il ruolo ricoperto:</strong> <%= submission.analysis.summary.roleFit.score %>%</p>
      <% } %>
      <p><strong>Indice di coerenza delle risposte:</strong> <%= submission.analysis.reliabilityScore %>/100 — <%= submission.analysis.reliabilityLabel %></p>
      <% if (submission.analysis.reliabilityFlags && submission.analysis.reliabilityFlags.length) { %>
        <p class="muted"><%= submission.analysis.reliabilityFlags.join("; ") %></p>
      <% } %>
    </div>

    <% if (submission.analysis.expandedReport.traits && submission.analysis.expandedReport.traits.length) { %>
      <div class="card">
        <h2>Approfondimento dei tratti</h2>
      </div>

      <% submission.analysis.expandedReport.traits.forEach(function(item) { %>
        <div class="card">
          <h3><%= item.displayName || item.name || "Tratto" %></h3>

          <% if (item.description) { %>
            <p class="muted">(<%= item.description %>)</p>
          <% } %>

          <p><%= item.expandedText || "-" %></p>

          <% if (item.showRemedies !== false) { %>
            <p><strong>Rimedi pratici:</strong> <%= item.improvementPlan || "-" %></p>
          <% } %>

          <p><strong>Come gestirlo nella pratica:</strong> <%= item.skillAction || item.teamLeverage || "-" %></p>
        </div>
      <% }) %>
    <% } %>
  <% } %>

  <script>
    const formsToDisable = [
      ["generate-expanded-form", "generate-expanded-button", "Generazione in corso..."],
      ["regenerate-expanded-form", "regenerate-expanded-button", "Rigenerazione in corso..."]
    ];

    formsToDisable.forEach(function ([formId, buttonId, loadingText]) {
      const form = document.getElementById(formId);
      const button = document.getElementById(buttonId);

      if (form && button) {
        form.addEventListener("submit", function () {
          button.disabled = true;
          button.innerText = loadingText;
          button.style.opacity = "0.7";
          button.style.cursor = "not-allowed";
        });
      }
    });
  </script>
</body>
</html>