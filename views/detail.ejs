<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <title>Dettaglio ZPI™ – Zenith Performance Index</title>

  <style>
    body { font-family: Arial, sans-serif; max-width: 1000px; margin: 40px auto; padding: 0 16px; }
    .card { border: 1px solid #ddd; border-radius: 12px; padding: 20px; margin-bottom: 20px; }
    .grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
    .trait { border: 1px solid #eee; border-radius: 10px; padding: 16px; }
    .muted { color: #666; }
    .topbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; gap: 16px; }
    .actions { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }

    .btn {
      display: inline-block;
      padding: 10px 14px;
      border: 0;
      border-radius: 8px;
      cursor: pointer;
      text-decoration: none;
      background: #111;
      color: #fff;
      font-size: 14px;
      line-height: 1.2;
    }

    .btn-secondary {
      background: #f5f5f5;
      color: #111;
      border: 1px solid #ddd;
    }

    .notice {
      padding: 14px 16px;
      margin: 16px 0 24px;
      border-radius: 10px;
      line-height: 1.45;
    }

    .notice-warning {
      background: #fff7ed;
      border: 1px solid #fed7aa;
      color: #9a3412;
    }

    .notice-success {
      background: #f0fdf4;
      border: 1px solid #bbf7d0;
      color: #166534;
    }

    .notice-error {
      background: #fee2e2;
      border: 1px solid #fecaca;
      color: #991b1b;
    }

    .notice strong {
      display: block;
      margin-bottom: 4px;
    }

    .histogram {
      margin: 18px 0 24px;
      padding: 18px;
      border: 1px solid #eee;
      border-radius: 12px;
      background: #fafafa;
    }

    .histogram-title {
      margin: 0 0 6px;
      font-size: 18px;
    }

    .histogram-help {
      margin: 0 0 16px;
      font-size: 13px;
      color: #666;
    }

    .histogram-scale {
      display: grid;
      grid-template-columns: 120px 1fr 44px;
      gap: 12px;
      align-items: center;
      margin-bottom: 8px;
      font-size: 12px;
      color: #777;
    }

    .histogram-scale-line {
      position: relative;
      height: 18px;
      border-bottom: 1px solid #ddd;
    }

    .histogram-scale-line::before {
      content: "";
      position: absolute;
      left: 50%;
      top: 0;
      bottom: -1px;
      width: 1px;
      background: #aaa;
    }

    .histogram-scale-labels {
      display: flex;
      justify-content: space-between;
    }

    .histogram-row {
      display: grid;
      grid-template-columns: 120px 1fr 44px;
      gap: 12px;
      align-items: center;
      margin: 12px 0;
    }

    .histogram-name {
      font-size: 14px;
      font-weight: 700;
    }

    .histogram-track {
      position: relative;
      height: 22px;
      background: #f1f1f1;
      border-radius: 999px;
      overflow: hidden;
      border: 1px solid #e5e5e5;
    }

    .histogram-track::before {
      content: "";
      position: absolute;
      left: 50%;
      top: 0;
      bottom: 0;
      width: 1px;
      background: #999;
      z-index: 2;
    }

    .histogram-bar {
      position: absolute;
      top: 3px;
      height: 14px;
      border-radius: 999px;
    }

    .histogram-bar-positive {
      left: 50%;
      background: #111;
    }

    .histogram-bar-negative {
      right: 50%;
      background: #999;
    }

    .histogram-score {
      font-size: 14px;
      font-weight: 700;
      text-align: right;
    }

    .answers-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 12px;
      font-size: 14px;
    }

    .answers-table th,
    .answers-table td {
      border: 1px solid #e5e5e5;
      padding: 10px;
      text-align: left;
      vertical-align: top;
    }

    .answers-table th {
      background: #f7f7f7;
    }

    .diagnostic-summary {
      cursor: pointer;
      font-weight: 700;
      padding: 10px 0;
    }

    .diagnostic-meta {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin: 6px 0 12px;
    }

    .pill {
      display: inline-block;
      padding: 3px 8px;
      border-radius: 999px;
      background: #f2f2f2;
      font-size: 12px;
      color: #333;
    }

    form { margin: 0; }

    @media (max-width: 700px) {
      .topbar {
        align-items: flex-start;
        flex-direction: column;
      }

      .grid {
        grid-template-columns: 1fr;
      }

      .histogram-scale,
      .histogram-row {
        grid-template-columns: 1fr;
        gap: 6px;
      }

      .histogram-score {
        text-align: left;
      }

      .histogram-name {
        font-size: 13px;
      }

      .answers-table {
        font-size: 13px;
      }
    }
  </style>

<%

  function cleanDisplayText(value) {
    if (value === null || value === undefined) return "";
    return String(value)
      // Mojibake / UTF-8 letto come latin1.
      .replace(/ZPIâ„¢/g, "ZPI™")
      .replace(/â€“/g, "–")
      .replace(/â€”/g, "—")
      .replace(/â€™/g, "’")
      .replace(/â€˜/g, "‘")
      .replace(/â€œ/g, "“")
      .replace(/â€/g, "”")
      .replace(/â€¦/g, "…")
      .replace(/â€¢/g, "•")
      .replace(/Ã /g, "à")
      .replace(/Ã¨/g, "è")
      .replace(/Ã©/g, "é")
      .replace(/Ã¬/g, "ì")
      .replace(/Ã²/g, "ò")
      .replace(/Ã¹/g, "ù")
      .replace(/Ã€/g, "À")
      .replace(/Ãˆ/g, "È")
      .replace(/Ã‰/g, "É")
      .replace(/ÃŒ/g, "Ì")
      .replace(/Ã’/g, "Ò")
      .replace(/Ã™/g, "Ù")
      .replace(/Â°/g, "°")
      .replace(/Â/g, "")
      // Accenti persi frequentemente nei testi AI/HTML.
      .replace(/\bpu\b/gi, function(match) { return match === match.toUpperCase() ? "PUÒ" : "può"; })
      .replace(/\bpi\b/g, "più")
      .replace(/\bPi\b/g, "Più")
      .replace(/\bci che\b/g, "ciò che")
      .replace(/\bCi che\b/g, "Ciò che")
      .replace(/\bperch\b/g, "perché")
      .replace(/\bPerch\b/g, "Perché")
      .replace(/\bcos\b/g, "così")
      .replace(/\bCos\b/g, "Così")
      .replace(/\bfuori da s\b/g, "fuori da sé")
      .replace(/\bFuori da s\b/g, "Fuori da sé")
      .replace(/\bd['’]quipe\b/g, "d’équipe")
      .replace(/\bdquipe\b/g, "d’équipe")
      .replace(/\blavoro d['’]?quipe\b/g, "lavoro d’équipe")
      .replace(/\bpossibilit\b/g, "possibilità")
      .replace(/\bPossibilit\b/g, "Possibilità")
      .replace(/\bcapacit\b/g, "capacità")
      .replace(/\bCapacit\b/g, "Capacità")
      .replace(/\bqualit\b/g, "qualità")
      .replace(/\bQualit\b/g, "Qualità")
      .replace(/\bcontinuit\b/g, "continuità")
      .replace(/\bContinuit\b/g, "Continuità")
      .replace(/\bresponsabilit\b/g, "responsabilità")
      .replace(/\bResponsabilit\b/g, "Responsabilità")
      .replace(/\baffidabilit\b/g, "affidabilità")
      .replace(/\bAffidabilit\b/g, "Affidabilità")
      .replace(/\bflessibilit\b/g, "flessibilità")
      .replace(/\bFlessibilit\b/g, "Flessibilità")
      .replace(/\badattabilit\b/g, "adattabilità")
      .replace(/\bAdattabilit\b/g, "Adattabilità")
      .replace(/\bstabilit\b/g, "stabilità")
      .replace(/\bStabilit\b/g, "Stabilità")
      .replace(/\binstabilit\b/g, "instabilità")
      .replace(/\bInstabilit\b/g, "Instabilità")
      .replace(/\bvalidit\b/g, "validità")
      .replace(/\bValidit\b/g, "Validità")
      .replace(/\battivit\b/g, "attività")
      .replace(/\bAttivit\b/g, "Attività")
      .replace(/\bmodalit\b/g, "modalità")
      .replace(/\bModalit\b/g, "Modalità")
      .replace(/\bpriorit\b/g, "priorità")
      .replace(/\bPriorit\b/g, "Priorità")
      .replace(/\bsostenibilit\b/g, "sostenibilità")
      .replace(/\bSostenibilit\b/g, "Sostenibilità")
      .replace(/\bopportunit\b/g, "opportunità")
      .replace(/\bOpportunit\b/g, "Opportunità")
      .replace(/\bcriticit\b/g, "criticità")
      .replace(/\bCriticit\b/g, "Criticità")
      .replace(/\bambiguit\b/g, "ambiguità")
      .replace(/\bAmbiguit\b/g, "Ambiguità")
      .replace(/\bcentralit\b/g, "centralità")
      .replace(/\bCentralit\b/g, "Centralità")
      .replace(/\bvisibilit\b/g, "visibilità")
      .replace(/\bVisibilit\b/g, "Visibilità")
      .replace(/\bdisponibilit\b/g, "disponibilità")
      .replace(/\bDisponibilit\b/g, "Disponibilità")
      // Frasi ricorrenti dove l'AI perde il verbo essere.
      .replace(/\bIl rischio per quello\b/g, "Il rischio è quello")
      .replace(/\bIl rischio quello\b/g, "Il rischio è quello")
      .replace(/\bil rischio per quello\b/g, "il rischio è quello")
      .replace(/\bil rischio quello\b/g, "il rischio è quello")
      .replace(/\bse il cambiamento spiegato\b/g, "se il cambiamento è spiegato")
      .replace(/\bSe il cambiamento spiegato\b/g, "Se il cambiamento è spiegato")
      .replace(/\bquando il cambiamento spiegato\b/g, "quando il cambiamento è spiegato")
      .replace(/\bQuando il cambiamento spiegato\b/g, "Quando il cambiamento è spiegato")
      .replace(/\bse il contesto confuso\b/g, "se il contesto è confuso")
      .replace(/\bSe il contesto confuso\b/g, "Se il contesto è confuso")
      .replace(/\bquando il contesto confuso\b/g, "quando il contesto è confuso")
      .replace(/\bQuando il contesto confuso\b/g, "Quando il contesto è confuso")
      .replace(/\bquesto aspetto rilevante\b/g, "questo aspetto è rilevante")
      .replace(/\bQuesto aspetto rilevante\b/g, "Questo aspetto è rilevante")
      .replace(/\bil tema collegato\b/g, "il tema è collegato")
      .replace(/\bIl tema collegato\b/g, "Il tema è collegato")
      .replace(/\bL’apertura al cambiamento presente\b/g, "L’apertura al cambiamento è presente")
      .replace(/\bl’apertura al cambiamento presente\b/g, "l’apertura al cambiamento è presente")
      .replace(/\bUtile leggere questo tratto\b/g, "È utile leggere questo tratto")
      .replace(/\butile leggere questo tratto\b/g, "è utile leggere questo tratto");
  }

  function cleanDisplayList(values, separator) {
    if (!Array.isArray(values)) return cleanDisplayText(values);
    return values.map(cleanDisplayText).filter(Boolean).join(separator || ", ");
  }

  function safeText(value, fallback) {
    const cleaned = cleanDisplayText(value);
    return cleaned || fallback || "-";
  }

%>

  <% if (submission.analysis.isValidated) { %>
    <div class="notice notice-success">
      <strong>Relazione validata.</strong>
      Il PDF usa la versione Word revisionata caricata dal Super Admin.
      <% if (submission.analysis.validatedAt) { %>
        Validata il <%= new Date(submission.analysis.validatedAt).toLocaleString('it-IT', { timeZone: 'Europe/Rome' }) %>.
      <% } %>
    </div>
  <% } else { %>
    <div class="notice notice-warning">
      <strong>Relazione non ancora validata.</strong>
      Il report è disponibile, ma non risulta ancora revisionato e validato da un Super Admin.
    </div>
  <% } %>

  <% if (isGenerating) { %>
    <meta http-equiv="refresh" content="8">
  <% } %>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="shortcut icon" href="/favicon.svg">
</head>

<body>
  <div class="topbar">
    <p><a href="/admin">← Torna alla lista</a></p>

    <div class="actions">
      <a class="btn btn-secondary" href="/admin/<%= submission.id %>/pdf" target="_blank">
        Apri PDF
      </a>

      <% if (currentAdmin && currentAdmin.role === "SUPER_ADMIN") { %>
        <a class="btn btn-secondary" href="/admin/<%= submission.id %>/word">
          Esporta Word
        </a>

        <form method="POST" action="/admin/<%= submission.id %>/validate-ai" onsubmit="return confirm('Validare la relazione AI corrente senza caricare un nuovo file?');">
              <button type="submit">Valida relazione AI corrente</button>
            </form>
            <form method="POST" action="/admin/<%= submission.id %>/upload-validated-report" enctype="multipart/form-data">
          <input type="file" name="reportFile" accept=".doc,.docx" required>
          <button class="btn btn-secondary" type="submit">
            Carica Word validato
          </button>
        </form>

        <% if (submission.analysis.isValidated) { %>
          <form method="POST" action="/admin/<%= submission.id %>/unvalidate-report" onsubmit="return confirm('Rimuovere lo stato validato da questa relazione?');">
            <button class="btn btn-secondary" type="submit">
              Rimuovi validazione
            </button>
          </form>
        <% } %>
      <% } %>

      <% if (!isGenerating && currentAdmin && currentAdmin.role === "SUPER_ADMIN") { %>
        <% if (submission.analysis.expandedReport) { %>
          <form method="POST" action="/admin/<%= submission.id %>/regenerate-expanded-report" id="regenerate-expanded-form">
            <button class="btn" type="submit" id="regenerate-expanded-button" onclick="return confirm('Rigenerare la relazione AI? La relazione attuale verrà sostituita.');">
              Rigenera relazione AI
            </button>
          </form>
        <% } else { %>
          <form method="POST" action="/admin/<%= submission.id %>/generate-expanded-report" id="generate-expanded-form">
            <button class="btn" type="submit" id="generate-expanded-button">
              Genera relazione AI
            </button>
          </form>
        <% } %>

        <form method="POST" action="/admin/<%= submission.id %>/recalculate-scoring-v2" id="recalculate-scoring-v2-form">
          <input type="hidden" name="regenerateAi" value="true">
          <button class="btn btn-secondary" type="submit" id="recalculate-scoring-v2-button" onclick="return confirm('Confermi il ricalcolo scoring V2.2? I punteggi verranno ricalcolati dalle risposte grezze e la relazione AI verrà rigenerata.');">
            Ricalcola scoring V2.2 + rigenera AI
          </button>
        </form>

        <form method="POST" action="/admin/<%= submission.id %>/duplicate-test">
          <button class="btn btn-secondary" type="submit">
            Duplica test veloce
          </button>
        </form>

        <form method="POST" action="/admin/<%= submission.id %>/duplicate-test">
          <input type="hidden" name="generateAi" value="yes">
          <button class="btn btn-secondary" type="submit">
            Duplica + rigenera relazione
          </button>
        </form>
      <% } %>
    </div>
  </div>

  <% if (isGenerating) { %>
    <div class="notice notice-warning">
      <strong>Relazione in generazione.</strong>
      Il report esploso è in preparazione. La pagina si aggiornerà automaticamente.
    </div>
  <% } %>

  <% if (submission.analysis.generationError) { %>
    <div class="notice notice-error">
      <strong>Generazione non completata.</strong>
      <%= safeText(submission.analysis.generationError) %>. Puoi rilanciare la generazione dal pulsante fallback.
    </div>
  <% } %>

  <% if (submission.analysis.validatedReportText) { %>
    <div class="card">
      <h2>Relazione generale validata</h2>
      <p style="white-space: pre-line;"><%= safeText(submission.analysis.validatedReportText) %></p>
    </div>
  <% } else if (submission.analysis.expandedReport) { %>
    <div class="card">
      <h2>Relazione generale</h2>
      <p><%= safeText(submission.analysis.expandedReport.generalSummary) %></p>
      <% if (submission.analysis.summary.roleFit && submission.analysis.summary.roleFit.score !== undefined) { %>
        <p><strong>Compatibilità con il ruolo ricoperto:</strong> <%= submission.analysis.summary.roleFit.score %>%</p>
      <% } %>
      <p><strong>Indice di coerenza delle risposte:</strong> <%= submission.analysis.reliabilityScore %>/100 — <%= safeText(submission.analysis.reliabilityLabel) %></p>
      <% if (submission.analysis.reliabilityFlags && submission.analysis.reliabilityFlags.length) { %>
        <p class="muted"><%= cleanDisplayList(submission.analysis.reliabilityFlags, "; ") %></p>
      <% } %>
    </div>

    <% if (submission.analysis.expandedReport.traits && submission.analysis.expandedReport.traits.length) { %>
      <div class="card">
        <h2>Approfondimento dei tratti</h2>
      </div>

      <% submission.analysis.expandedReport.traits.forEach(function(item) { %>
        <div class="card">
          <h3><%= safeText(item.displayName || item.name, "Tratto") %></h3>

          <% if (item.description) { %>
            <p class="muted">(<%= safeText(item.description) %>)</p>
          <% } %>

          <p><%= safeText(item.expandedText) %></p>

          <% if (item.showRemedies !== false) { %>
            <p><strong>Rimedi pratici:</strong> <%= safeText(item.improvementPlan) %></p>
          <% } %>

          <% if (item.showSkillAction !== false) { %>
            <p><strong>Come gestirlo nella pratica:</strong> <%= safeText(item.skillAction || item.teamLeverage) %></p>
          <% } %>
        </div>
      <% }) %>
    <% } %>
  <% } %>

  <% if (currentAdmin && currentAdmin.role === "SUPER_ADMIN" && submission.analysis.dimensionDiagnostics && submission.analysis.dimensionDiagnostics.length) { %>
    <div class="card">
      <h2>Diagnostica scoring V2.2</h2>
      <p class="muted">
        Mostra quali risposte alimentano ogni tratto/parametro dopo il ricalcolo V2.2. Serve per verificare casi anomali come 100, 0 o salti molto ampi rispetto allo scoring legacy.
      </p>

      <% submission.analysis.dimensionDiagnostics.forEach(function(dimension) { %>
        <details>
          <summary class="diagnostic-summary">
            <%= safeText(dimension.displayName || dimension.name) %> — score <%= dimension.chartScore %> — <%= dimension.questionCount %> item
          </summary>
          <div class="diagnostic-meta">
            <span class="pill"><%= dimension.category === "additional" ? "Parametro aggiuntivo" : "Tratto" %></span>
            <span class="pill">raw score: <%= dimension.score %></span>
          </div>

          <% if (dimension.items && dimension.items.length) { %>
            <table class="answers-table">
              <thead>
                <tr>
                  <th style="width: 70px;">Q</th>
                  <th>Domanda</th>
                  <th style="width: 150px;">Risposta</th>
                  <th style="width: 80px;">Reverse</th>
                  <th style="width: 70px;">Valore</th>
                  <th style="width: 180px;">Origine</th>
                </tr>
              </thead>
              <tbody>
                <% dimension.items.forEach(function(item) { %>
                  <tr>
                    <td><strong><%= item.questionKey %></strong></td>
                    <td>
                      <%= safeText(item.text) %>
                      <% if (item.subDimension) { %>
                        <br><span class="muted"><%= safeText(item.subDimension) %></span>
                      <% } %>
                    </td>
                    <td><%= safeText(item.answerLabel || item.answer) %></td>
                    <td><%= item.reverse ? "Sì" : "No" %></td>
                    <td><strong><%= item.value %></strong></td>
                    <td><%= safeText(item.sourceTrait) %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } else { %>
            <p class="muted">Nessun item alimenta questa dimensione.</p>
          <% } %>
        </details>
      <% }) %>
    </div>
  <% } %>

  <script>
    const formsToDisable = [
      ["generate-expanded-form", "generate-expanded-button", "Generazione in corso..."],
      ["regenerate-expanded-form", "regenerate-expanded-button", "Rigenerazione in corso..."],
      ["recalculate-scoring-v2-form", "recalculate-scoring-v2-button", "Ricalcolo V2.2 in corso..."]
    ];

    formsToDisable.forEach(function ([formId, buttonId, loadingText]) {
      const form = document.getElementById(formId);
      const button = document.getElementById(buttonId);

      if (form && button) {
        form.addEventListener("submit", function () {
          button.disabled = true;
          button.innerText = loadingText;
          button.style.opacity = "0.7";
          button.style.cursor = "not-allowed";
        });
      }
    });
  </script>
</body>
</html>