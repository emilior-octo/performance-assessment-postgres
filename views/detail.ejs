<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Dettaglio Assessment</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  <style>
    :root { --zenith: #2F4B7C; --border: #e5e7eb; --muted: #666; --bg: #f7f8fb; }
    body { font-family: Arial, sans-serif; max-width: 1060px; margin: 40px auto; padding: 0 16px; color: #111827; background: #fff; }
    h1, h2, h3 { margin-top: 0; }
    .card { border: 1px solid var(--border); border-radius: 14px; padding: 22px; margin-bottom: 20px; background: #fff; }
    .grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
    .trait { border: 1px solid #eee; border-radius: 12px; padding: 16px; background: #fcfcfd; }
    .trait h3 { margin-bottom: 6px; }
    .description { color: var(--muted); font-size: 13px; line-height: 1.45; margin-top: 0; }
    .muted { color: var(--muted); }
    .topbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; gap: 16px; }
    .actions { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; justify-content: flex-end; }
    .btn { display: inline-block; padding: 10px 14px; border: 0; border-radius: 999px; cursor: pointer; text-decoration: none; background: var(--zenith); color: #fff; font-size: 14px; line-height: 1.2; }
    .btn-secondary { background: #f5f5f5; color: #111; border: 1px solid #ddd; }
    .notice { padding: 14px 16px; margin: 16px 0 24px; border-radius: 10px; line-height: 1.45; }
    .notice-warning { background: #fff7ed; border: 1px solid #fed7aa; color: #9a3412; }
    .notice-error { background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; }
    .notice-success { background: #f0fdf4; border: 1px solid #bbf7d0; color: #166534; }
    .relation { white-space: pre-line; line-height: 1.6; }
    .split-title { margin-top: 24px; padding-top: 18px; border-top: 1px solid var(--border); }
    .score { color: var(--zenith); font-weight: 700; }
    .answers-table { width: 100%; border-collapse: collapse; font-size: 14px; }
    .answers-table th, .answers-table td { border-bottom: 1px solid #eee; padding: 10px; vertical-align: top; text-align: left; }
    .answers-table th { background: #fafafa; }
    @media (max-width: 760px) { body { margin: 24px auto; } .grid { grid-template-columns: 1fr; } .topbar { align-items: flex-start; flex-direction: column; } .actions { justify-content: flex-start; } }
  </style>

  <% if (isGenerating) { %>
    <meta http-equiv="refresh" content="8">
  <% } %>
</head>

<body>
  <div class="topbar">
    <p><a href="/admin">← Torna alla lista</a></p>

    <div class="actions">
      <a class="btn btn-secondary" href="/admin/<%= submission.id %>/pdf" target="_blank">Apri PDF</a>

      <form method="POST" action="/admin/<%= submission.id %>/duplicate-test">
        <input type="hidden" name="generateAi" value="no">
        <button class="btn btn-secondary" type="submit">Duplica test veloce</button>
      </form>

      <form method="POST" action="/admin/<%= submission.id %>/duplicate-test">
        <input type="hidden" name="generateAi" value="yes">
        <button class="btn btn-secondary" type="submit">Duplica + rigenera relazione</button>
      </form>

      <% if (!submission.analysis.expandedReport && !isGenerating) { %>
        <form method="POST" action="/admin/<%= submission.id %>/generate-expanded-report" id="generate-expanded-form">
          <button class="btn" type="submit" id="generate-expanded-button">Genera relazione</button>
        </form>
      <% } %>
    </div>
  </div>

  <% if (isGenerating) { %>
    <div class="notice notice-warning"><strong>Relazione in generazione.</strong> La pagina si aggiornerà automaticamente.</div>
  <% } %>

  <% if (submission.analysis.generationError) { %>
    <div class="notice notice-error"><strong>Generazione non completata.</strong> <%= submission.analysis.generationError %>.</div>
  <% } %>

  <% if (submission.analysis.expandedReport) { %>
    <div class="notice notice-success"><strong>Relazione disponibile.</strong> Il report è stato generato correttamente ed è incluso anche nel PDF.</div>
  <% } %>

  <h1>Dettaglio Assessment</h1>
  <p class="muted"><strong>Azienda:</strong> <%= organizationName %></p>

  <div class="card">
    <h2>Dati compilazione</h2>
    <ul>
      <li><strong>ID:</strong> <%= submission.id %></li>
      <li><strong>Nome:</strong> <%= submission.name %></li>
      <li><strong>Email:</strong> <%= submission.email || "-" %></li>
      <li><strong>Età:</strong> <%= submission.age || "-" %></li>
      <li><strong>Azienda risorsa:</strong> <%= submission.candidateCompany || "-" %></li>
      <li><strong>Ruolo:</strong> <%= submission.role %></li>
      <li><strong>Data:</strong> <%= new Date(submission.createdAt).toLocaleString("it-IT") %></li>
    </ul>
  </div>

  <div class="card">
    <h2>Relazione generale</h2>
    <div class="relation"><%= submission.analysis.summary.generalRelation || "-" %></div>

    <h3 class="split-title">Indicazione pratica per la gestione</h3>
    <div class="relation"><%= submission.analysis.summary.managementAdvice || "-" %></div>

    <% if (submission.analysis.reliabilityFlags && submission.analysis.reliabilityFlags.length) { %>
      <h3 class="split-title">Nota da tenere presente</h3>
      <p>Alcune risposte mostrano oscillazioni interne. Il risultato va quindi letto con attenzione e verificato nel confronto diretto con la persona.</p>
    <% } %>
  </div>

  <div class="card">
    <h2>Dettaglio tratti e parametri aggiuntivi</h2>

    <h3>Tratti</h3>
    <% if (submission.analysis.mainTraits && submission.analysis.mainTraits.length) { %>
      <div class="grid">
        <% submission.analysis.mainTraits.forEach(function(item) { %>
          <div class="trait">
            <h3><%= item.displayName || item.name %>: <span class="score"><%= item.chartScore ?? item.score %></span></h3>
            <% if (item.description) { %><p class="description">(<%= item.description %>)</p><% } %>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p class="muted">Nessun dettaglio tratti disponibile.</p>
    <% } %>

    <h3 class="split-title">Parametri aggiuntivi</h3>
    <% if (submission.analysis.additionalParameters && submission.analysis.additionalParameters.length) { %>
      <div class="grid">
        <% submission.analysis.additionalParameters.forEach(function(item) { %>
          <div class="trait">
            <h3><%= item.displayName || item.name %>: <span class="score"><%= item.chartScore ?? item.score %></span></h3>
            <% if (item.description) { %><p class="description">(<%= item.description %>)</p><% } %>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p class="muted">Nessun parametro aggiuntivo disponibile.</p>
    <% } %>
  </div>

  <% if (submission.analysis.expandedReport && submission.analysis.expandedReport.traits && submission.analysis.expandedReport.traits.length) { %>
    <div class="card">
      <h2>Approfondimento dei tratti</h2>
      <p class="muted">Stessa struttura della relazione PDF: spiegazione, rimedi pratici e indicazioni di gestione.</p>
    </div>

    <% submission.analysis.expandedReport.traits.forEach(function(item) { %>
      <div class="card">
        <h3><%= item.displayName || item.name || "Tratto" %></h3>
        <% if (item.description) { %><p class="description">(<%= item.description %>)</p><% } %>

        <p><%= item.expandedText || "-" %></p>

        <p><strong>Rimedi pratici</strong></p>
        <p><%= item.improvementPlan || "-" %></p>

        <p><strong>Come gestirlo nella pratica</strong></p>
        <p><%= item.skillAction || item.teamLeverage || "-" %></p>
      </div>
    <% }) %>
  <% } %>

  <div class="card">
    <h2>Risposte grezze</h2>

    <% if (submission.analysis.answers && Object.keys(submission.analysis.answers).length) { %>
      <table class="answers-table">
        <thead>
          <tr><th>#</th><th>Domanda</th><th>Risposta</th></tr>
        </thead>
        <tbody>
          <% Object.keys(submission.analysis.questions).forEach(function(key, index) {
            const answer = submission.analysis.answers[key];
            let label = "-";
            if (answer === "agree") label = "D’accordo";
            if (answer === "uncertain") label = "Incerto / parzialmente";
            if (answer === "disagree") label = "In disaccordo";
          %>
            <tr>
              <td><%= index + 1 %></td>
              <td><%= submission.analysis.questions[key] %></td>
              <td><%= label %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else { %>
      <p class="muted">Risposte grezze non disponibili per questa compilazione.</p>
    <% } %>
  </div>

  <script>
    const form = document.getElementById("generate-expanded-form");
    const button = document.getElementById("generate-expanded-button");
    if (form && button) {
      form.addEventListener("submit", function () {
        button.disabled = true;
        button.innerText = "Generazione in corso...";
        button.style.opacity = "0.7";
        button.style.cursor = "not-allowed";
      });
    }
  </script>
</body>
</html>
