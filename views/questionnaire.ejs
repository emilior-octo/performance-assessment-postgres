<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title><%= typeof assessmentTitle !== "undefined" ? assessmentTitle : "ZPI™ – Zenith Performance Index" %></title>

  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #f4f7fb;
      color: #111827;
    }

    .page {
      min-height: 100vh;
      padding: 28px 16px;
    }

    .shell {
      width: 100%;
      max-width: 920px;
      margin: 0 auto;
    }

    .header {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 22px;
      overflow: hidden;
      margin-bottom: 20px;
      box-shadow: 0 14px 40px rgba(15, 23, 42, 0.06);
    }

    .brand-band {
      background: linear-gradient(135deg, #0b6fb3, #1685cf);
      padding: 26px 20px;
      text-align: center;
    }

    .brand-logo {
      width: min(420px, 88%);
      max-height: 100px;
      object-fit: contain;
      display: block;
      margin: 0 auto;
    }

    .header-content {
      padding: 26px;
    }

    .eyebrow {
      margin: 0 0 8px;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #0b6fb3;
      font-weight: 700;
    }

    h1 {
      margin: 0 0 10px;
      font-size: clamp(28px, 4vw, 40px);
      letter-spacing: -0.03em;
    }

    .intro {
      margin: 0;
      color: #4b5563;
      line-height: 1.6;
      font-size: 16px;
    }

    form {
      margin: 0;
    }

    .card {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 18px;
      padding: 22px;
      margin-bottom: 18px;
    }

    .card h2 {
      margin: 0 0 16px;
      font-size: 20px;
    }

    label {
      display: block;
      font-weight: 700;
      margin-bottom: 8px;
    }

    .form-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px 16px;
      align-items: start;
    }

    .field {
      margin: 0;
    }

    .field-full {
      grid-column: 1 / -1;
    }

    .field label {
      margin-bottom: 7px;
      font-size: 13px;
      color: #243b6b;
      letter-spacing: 0.01em;
    }

    input[type="text"],
    input[type="email"],
    input[type="number"],
    select {
      width: 100%;
      min-height: 48px;
      padding: 12px 14px;
      border: 1px solid #cfd7e6;
      border-radius: 14px;
      font-size: 16px;
      background: #fff;
      color: #111827;
      outline: none;
      transition: border-color 0.15s ease, box-shadow 0.15s ease, background-color 0.15s ease;
    }

    select {
      appearance: none;
      -webkit-appearance: none;
      padding-right: 44px;
      background-image:
        linear-gradient(45deg, transparent 50%, #263c7a 50%),
        linear-gradient(135deg, #263c7a 50%, transparent 50%),
        linear-gradient(to right, #eef3ff, #eef3ff);
      background-position:
        calc(100% - 24px) 20px,
        calc(100% - 17px) 20px,
        calc(100% - 46px) 0;
      background-size: 7px 7px, 7px 7px, 1px 100%;
      background-repeat: no-repeat;
    }

    input:focus,
    select:focus {
      border-color: #263c7a;
      box-shadow: 0 0 0 4px rgba(38, 60, 122, 0.12);
      background-color: #fbfdff;
    }

    .meta-card {
      border-color: #d9e3f3;
      background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
      box-shadow: 0 12px 30px rgba(38, 60, 122, 0.06);
    }

    .meta-card h2 {
      display: flex;
      align-items: center;
      gap: 10px;
      color: #111827;
    }

    .meta-card h2::before {
      content: "";
      width: 9px;
      height: 24px;
      border-radius: 999px;
      background: #263c7a;
      display: inline-block;
    }

    .question {
      padding: 18px 0;
      border-top: 1px solid #eef0f3;
    }

    .question:first-child {
      border-top: 0;
      padding-top: 0;
    }

    .question-title {
      margin: 0 0 12px;
      font-weight: 700;
      line-height: 1.45;
    }

    .options {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
    }

    .option {
      display: flex;
      gap: 8px;
      align-items: center;
      padding: 12px;
      border: 1px solid #d1d5db;
      border-radius: 12px;
      cursor: pointer;
      font-weight: 400;
      margin: 0;
    }

    .option input {
      width: 18px;
      height: 18px;
      margin: 0;
    }

    .actions {
      display: flex;
      justify-content: flex-end;
      margin-top: 18px;
    }

    .btn {
      border: 0;
      cursor: pointer;
      border-radius: 12px;
      background: #111827;
      color: #fff;
      padding: 14px 18px;
      font-size: 16px;
      font-weight: 700;
    }

    .muted {
      color: #6b7280;
      font-size: 14px;
      line-height: 1.5;
    }



    .validation-banner {
      display: none;
      margin-bottom: 16px;
      padding: 14px 16px;
      border: 1px solid #fecaca;
      background: #fff1f2;
      color: #991b1b;
      border-radius: 14px;
      font-size: 15px;
      line-height: 1.45;
      font-weight: 700;
    }

    .validation-banner.is-visible {
      display: block;
    }

    .progress-box {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      padding: 12px 14px;
      margin: 0 0 18px;
      border: 1px solid #d9e3f3;
      border-radius: 14px;
      background: #f8fbff;
      color: #243b6b;
      font-size: 14px;
      line-height: 1.4;
    }

    .progress-box strong {
      color: #263c7a;
    }

    .progress-track {
      flex: 1;
      min-width: 120px;
      height: 8px;
      border-radius: 999px;
      background: #e5e7eb;
      overflow: hidden;
    }

    .progress-bar {
      width: 0%;
      height: 100%;
      border-radius: 999px;
      background: #263c7a;
      transition: width 0.2s ease;
    }

    .question {
      scroll-margin-top: 24px;
      border-radius: 14px;
      transition: background-color 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
    }

    .question.is-missing {
      padding-left: 14px;
      padding-right: 14px;
      background: #fff7ed;
      box-shadow: inset 0 0 0 2px #fb923c;
    }

    .question.is-missing .question-title::after {
      content: "Risposta obbligatoria";
      display: inline-block;
      margin-left: 8px;
      padding: 3px 8px;
      border-radius: 999px;
      background: #ffedd5;
      color: #9a3412;
      font-size: 12px;
      font-weight: 800;
      vertical-align: middle;
    }

    .field.is-missing input,
    .field.is-missing select {
      border-color: #fb923c;
      box-shadow: 0 0 0 4px rgba(251, 146, 60, 0.18);
      background: #fff7ed;
    }

    .field-error {
      display: none;
      margin-top: 6px;
      color: #9a3412;
      font-size: 13px;
      font-weight: 700;
    }

    .field.is-missing .field-error {
      display: block;
    }

    @media (max-width: 720px) {
      .page {
        padding: 16px;
      }

      .header-content,
      .card {
        padding: 18px;
      }

      .form-grid {
        grid-template-columns: 1fr;
        gap: 14px;
      }

      .options {
        grid-template-columns: 1fr;
      }

      .progress-box {
        align-items: flex-start;
        flex-direction: column;
      }

      .progress-track {
        width: 100%;
      }

      .actions {
        justify-content: stretch;
      }

      .btn {
        width: 100%;
      }
    }
  </style>
</head>

<body>
  <main class="page">
    <div class="shell">
      <header class="header">
        <div class="brand-band">
          <img class="brand-logo" src="/zenith-logo.jpeg" alt="Zenith 360" />
        </div>

        <div class="header-content">
          <p class="eyebrow">Questionario assessment</p>
          <h1><%= typeof assessmentTitle !== "undefined" ? assessmentTitle : "ZPI™ – Zenith Performance Index" %></h1>

          <p class="intro">
            Compila il questionario rispondendo in modo spontaneo e coerente con il tuo comportamento abituale nel contesto lavorativo.
            Non esistono risposte giuste o sbagliate.
          </p>
        </div>
      </header>

      <form method="POST" action="/q/<%= token %>" id="assessment-form" novalidate>
        <div id="validation-banner" class="validation-banner" role="alert" aria-live="assertive">
          Completa tutte le domande obbligatorie prima di continuare. Ti abbiamo portato al primo punto da completare.
        </div>

        <section class="card meta-card">
          <h2>Dati compilazione</h2>

          <div class="form-grid">
            <div class="field">
              <label for="respondentName">Nome e cognome</label>
              <input id="respondentName" type="text" name="respondentName" required />
              <span class="field-error">Campo obbligatorio.</span>
            </div>

            <div class="field">
              <label for="respondentEmail">Email</label>
              <input id="respondentEmail" type="email" name="respondentEmail" />
            </div>

            <div class="field">
              <label for="age">Età</label>
              <input id="age" type="number" name="age" min="16" max="100" placeholder="Es. 41" />
            </div>

            <div class="field">
              <label for="candidateCompany">Azienda / Cliente di riferimento</label>
              <input id="candidateCompany" type="text" name="candidateCompany" placeholder="Es. Zenith 360" />
            </div>

            <div class="field field-full">
              <label for="requestedRole">Ruolo ricoperto / ruolo di riferimento</label>
              <select id="requestedRole" name="requestedRole" required>
                <option value="" disabled selected>Seleziona un ruolo</option>
                <% (roleOptions || []).forEach(function(role) { %>
                  <option value="<%= role.value %>" <%= requestedRole === role.value ? "selected" : "" %>><%= role.label %></option>
                <% }) %>
              </select>
              <span class="field-error">Seleziona un ruolo.</span>
            </div>

            <div class="field field-full" id="requestedRoleOtherWrap" style="display: none;">
              <label for="requestedRoleOther">Specifica altro ruolo</label>
              <input id="requestedRoleOther" type="text" name="requestedRoleOther" placeholder="Es. buyer, responsabile acquisti, tecnico, impiegato..." />
              <span class="field-error">Specifica il ruolo.</span>
            </div>
          </div>

          <p class="muted" style="margin-top: 16px; margin-bottom: 0;">
            I dati saranno utilizzati esclusivamente per associare correttamente la compilazione al percorso di assessment.
          </p>
        </section>

        <section class="card">
          <h2>Domande</h2>

          <div class="progress-box" aria-live="polite">
            <span><strong id="answered-count">0</strong> / <strong id="total-count">0</strong> domande completate</span>
            <div class="progress-track" aria-hidden="true"><div class="progress-bar" id="progress-bar"></div></div>
          </div>

          <%
            const questionList = Array.isArray(questions)
              ? questions
              : Object.keys(questions).map(function(key) {
                  return { key: key, text: questions[key], responseType: "likert", options: null };
                });
          %>

          <% questionList.forEach(function(question, index) {
              const key = question.key;
              const opts = Array.isArray(question.options) && question.options.length
                ? question.options
                : [
                    { value: "agree", label: "Sono d’accordo" },
                    { value: "uncertain", label: "Incerto" },
                    { value: "disagree", label: "Non sono d’accordo" }
                  ];
          %>
            <div class="question" data-question-key="<%= key %>" data-question-number="<%= index + 1 %>">
              <p class="question-title"><%= index + 1 %>. <%= question.text %></p>

              <div class="options">
                <% opts.forEach(function(option) { %>
                  <label class="option">
                    <input type="radio" name="<%= key %>" value="<%= option.value %>" required />
                    <span><%= option.label %></span>
                  </label>
                <% }) %>
              </div>
            </div>
          <% }) %>

          <div class="actions">
            <button class="btn" type="submit" id="submit-button">
              Invia assessment
            </button>
          </div>
        </section>
      </form>
    </div>
  </main>

  <script>
    const form = document.getElementById("assessment-form");
    const button = document.getElementById("submit-button");
    const validationBanner = document.getElementById("validation-banner");
    const answeredCount = document.getElementById("answered-count");
    const totalCount = document.getElementById("total-count");
    const progressBar = document.getElementById("progress-bar");
    const questionsNodes = Array.from(document.querySelectorAll(".question[data-question-key]"));

    function clearValidationState() {
      document.querySelectorAll(".is-missing").forEach(function (node) {
        node.classList.remove("is-missing");
      });

      if (validationBanner) {
        validationBanner.classList.remove("is-visible");
      }
    }

    function getFirstMissingField() {
      const requiredFields = Array.from(form.querySelectorAll("input[required]:not([type='radio']), select[required], textarea[required]"));

      for (const field of requiredFields) {
        const isHidden = field.offsetParent === null;
        if (isHidden) continue;

        if (!String(field.value || "").trim()) {
          const wrapper = field.closest(".field") || field;
          wrapper.classList.add("is-missing");
          return field;
        }
      }

      return null;
    }

    function getFirstMissingQuestion() {
      for (const question of questionsNodes) {
        const key = question.getAttribute("data-question-key");
        if (!key) continue;

        const checked = form.querySelector(`input[type="radio"][name="${CSS.escape(key)}"]:checked`);
        if (!checked) {
          question.classList.add("is-missing");
          return question;
        }
      }

      return null;
    }

    function scrollToMissing(target) {
      if (!target) return;

      const scrollTarget = target.classList && target.classList.contains("question")
        ? target
        : (target.closest(".field") || target);

      scrollTarget.scrollIntoView({ behavior: "smooth", block: "center" });

      window.setTimeout(function () {
        const focusable = scrollTarget.querySelector("input, select, textarea, button") || target;
        if (focusable && typeof focusable.focus === "function") {
          focusable.focus({ preventScroll: true });
        }
      }, 350);
    }

    function updateProgress() {
      const total = questionsNodes.length;
      const completed = questionsNodes.filter(function (question) {
        const key = question.getAttribute("data-question-key");
        return !!form.querySelector(`input[type="radio"][name="${CSS.escape(key)}"]:checked`);
      }).length;

      if (answeredCount) answeredCount.textContent = String(completed);
      if (totalCount) totalCount.textContent = String(total);
      if (progressBar) progressBar.style.width = total ? `${Math.round((completed / total) * 100)}%` : "0%";
    }

    if (form && button) {
      updateProgress();

      form.addEventListener("change", function (event) {
        const target = event.target;

        if (target && target.type === "radio") {
          const question = target.closest(".question");
          if (question) question.classList.remove("is-missing");
          updateProgress();
        }

        if (target && target.matches("input, select, textarea")) {
          const field = target.closest(".field");
          if (field && String(target.value || "").trim()) field.classList.remove("is-missing");
        }
      });

      form.addEventListener("input", function (event) {
        const target = event.target;
        if (target && target.matches("input, textarea")) {
          const field = target.closest(".field");
          if (field && String(target.value || "").trim()) field.classList.remove("is-missing");
        }
      });

      form.addEventListener("submit", function (event) {
        event.preventDefault();
        clearValidationState();

        const firstMissingField = getFirstMissingField();
        const firstMissingQuestion = getFirstMissingQuestion();
        const firstMissing = firstMissingField || firstMissingQuestion;

        if (firstMissing) {
          if (validationBanner) {
            validationBanner.classList.add("is-visible");
          }

          scrollToMissing(firstMissing);
          updateProgress();
          return;
        }

        button.disabled = true;
        button.innerText = "Invio in corso...";
        button.style.opacity = "0.7";
        button.style.cursor = "not-allowed";

        HTMLFormElement.prototype.submit.call(form);
      });
    }
  </script>

  <script>
    const requestedRoleSelect = document.getElementById("requestedRole");
    const requestedRoleOtherWrap = document.getElementById("requestedRoleOtherWrap");
    const requestedRoleOtherInput = document.getElementById("requestedRoleOther");

    function syncOtherRoleField() {
      const isOther = requestedRoleSelect && requestedRoleSelect.value === "altro";
      if (requestedRoleOtherWrap) requestedRoleOtherWrap.style.display = isOther ? "block" : "none";
      if (requestedRoleOtherInput) {
        requestedRoleOtherInput.required = isOther;
        if (!isOther) requestedRoleOtherInput.value = "";
      }
    }

    if (requestedRoleSelect) {
      requestedRoleSelect.addEventListener("change", syncOtherRoleField);
      syncOtherRoleField();
    }
  </script>

</body>
</html>