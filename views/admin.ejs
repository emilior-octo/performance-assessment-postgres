<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <title>Area Admin</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      max-width: 1200px;
      margin: 40px auto;
      padding: 0 16px;
      color: #111827;
      background: #f7f9fc;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 16px;
      margin-bottom: 24px;
    }

    h1 {
      margin: 0 0 6px;
    }

    .muted {
      color: #666;
      margin: 0;
    }

    .card {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 14px;
      padding: 18px;
      margin-bottom: 18px;
    }

    .filters {
      display: flex;
      gap: 12px;
      align-items: flex-end;
      flex-wrap: wrap;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 6px;
      min-width: 260px;
    }

    label {
      font-size: 13px;
      font-weight: 700;
      color: #374151;
    }

    input,
    select {
      padding: 10px 12px;
      border: 1px solid #d1d5db;
      border-radius: 10px;
      font-size: 14px;
      background: #fff;
    }

    button,
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 10px 14px;
      border: 0;
      border-radius: 10px;
      cursor: pointer;
      text-decoration: none;
      background: #111827;
      color: #fff;
      font-size: 14px;
      font-weight: 700;
    }

    .btn-secondary {
      background: #f3f4f6;
      color: #111827;
      border: 1px solid #d1d5db;
    }

    .logout-btn {
      background: #f3f4f6;
      color: #111827;
      border: 1px solid #d1d5db;
    }

    .admin-actions {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 10px;
      flex-wrap: wrap;
    }

    .qr-card {
      display: grid;
      grid-template-columns: 130px minmax(0, 1fr);
      gap: 18px;
      align-items: center;
    }

    .qr-preview {
      width: 120px;
      height: 120px;
      border: 1px solid #e5e7eb;
      border-radius: 14px;
      padding: 8px;
      background: #fff;
    }

    .qr-preview img {
      width: 100%;
      height: 100%;
      display: block;
    }

    .qr-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 12px;
    }

    .link-copy {
      word-break: break-all;
      font-size: 13px;
      color: #4b5563;
      margin-top: 6px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: #fff;
      border-radius: 14px;
      overflow: hidden;
    }

    th,
    td {
      border: 1px solid #e5e7eb;
      padding: 10px;
      text-align: left;
      vertical-align: top;
      font-size: 14px;
    }

    th {
      background: #f3f4f6;
      font-size: 13px;
      color: #374151;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      padding: 5px 8px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 700;
      white-space: nowrap;
    }

    .badge-ready {
      background: #dcfce7;
      color: #166534;
      border: 1px solid #bbf7d0;
    }

    .badge-pending {
      background: #fff7ed;
      color: #9a3412;
      border: 1px solid #fed7aa;
    }

    .badge-error {
      background: #fee2e2;
      color: #991b1b;
      border: 1px solid #fecaca;
    }

    .actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .empty {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 14px;
      padding: 20px;
    }

    @media (max-width: 900px) {
      body {
        margin: 24px auto;
      }

      .topbar {
        flex-direction: column;
      }

      .admin-actions {
        width: 100%;
        justify-content: flex-start;
      }

      .qr-card {
        grid-template-columns: 1fr;
      }

      .field {
        min-width: 100%;
      }

      .filters {
        align-items: stretch;
      }

      .filters button,
      .filters .btn {
        width: 100%;
      }

      table {
        display: block;
        overflow-x: auto;
      }
    }
  </style>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="shortcut icon" href="/favicon.svg">
</head>

<body>
  <div class="topbar">
    <div>
      <h1>Area Admin</h1>
      <p class="muted"><%= safeText(organizationName) %></p>
    </div>

    <div class="admin-actions">
      <% if (currentAdmin && currentAdmin.role === "SUPER_ADMIN") { %>
        <a class="btn btn-secondary" href="/admin/users">Gestione utenti</a>
      <% } %>
      <a class="btn btn-secondary" href="<%= typeof homeUrl !== 'undefined' ? homeUrl : '/questionnaires' %>">Torna alla Home</a>
      <form method="POST" action="/admin/logout">
        <button class="logout-btn" type="submit">Logout</button>
      </form>
    </div>
  </div>

  <%

  function cleanDisplayText(value) {
    if (value === null || value === undefined) return "";
    return String(value)
      // Mojibake / UTF-8 letto come latin1.
      .replace(/ZPIâ„¢/g, "ZPI™")
      .replace(/â€“/g, "–")
      .replace(/â€”/g, "—")
      .replace(/â€™/g, "’")
      .replace(/â€˜/g, "‘")
      .replace(/â€œ/g, "“")
      .replace(/â€/g, "”")
      .replace(/â€¦/g, "…")
      .replace(/â€¢/g, "•")
      .replace(/Ã /g, "à")
      .replace(/Ã¨/g, "è")
      .replace(/Ã©/g, "é")
      .replace(/Ã¬/g, "ì")
      .replace(/Ã²/g, "ò")
      .replace(/Ã¹/g, "ù")
      .replace(/Ã€/g, "À")
      .replace(/Ãˆ/g, "È")
      .replace(/Ã‰/g, "É")
      .replace(/ÃŒ/g, "Ì")
      .replace(/Ã’/g, "Ò")
      .replace(/Ã™/g, "Ù")
      .replace(/Â°/g, "°")
      .replace(/Â/g, "")
      // Accenti persi frequentemente nei testi AI/HTML.
      .replace(/\bpu\b/gi, function(match) { return match === match.toUpperCase() ? "PUÒ" : "può"; })
      .replace(/\bpi\b/g, "più")
      .replace(/\bPi\b/g, "Più")
      .replace(/\bci che\b/g, "ciò che")
      .replace(/\bCi che\b/g, "Ciò che")
      .replace(/\bperch\b/g, "perché")
      .replace(/\bPerch\b/g, "Perché")
      .replace(/\bcos\b/g, "così")
      .replace(/\bCos\b/g, "Così")
      .replace(/\bfuori da s\b/g, "fuori da sé")
      .replace(/\bFuori da s\b/g, "Fuori da sé")
      .replace(/\bd['’]quipe\b/g, "d’équipe")
      .replace(/\bdquipe\b/g, "d’équipe")
      .replace(/\blavoro d['’]?quipe\b/g, "lavoro d’équipe")
      .replace(/\bpossibilit\b/g, "possibilità")
      .replace(/\bPossibilit\b/g, "Possibilità")
      .replace(/\bcapacit\b/g, "capacità")
      .replace(/\bCapacit\b/g, "Capacità")
      .replace(/\bqualit\b/g, "qualità")
      .replace(/\bQualit\b/g, "Qualità")
      .replace(/\bcontinuit\b/g, "continuità")
      .replace(/\bContinuit\b/g, "Continuità")
      .replace(/\bresponsabilit\b/g, "responsabilità")
      .replace(/\bResponsabilit\b/g, "Responsabilità")
      .replace(/\baffidabilit\b/g, "affidabilità")
      .replace(/\bAffidabilit\b/g, "Affidabilità")
      .replace(/\bflessibilit\b/g, "flessibilità")
      .replace(/\bFlessibilit\b/g, "Flessibilità")
      .replace(/\badattabilit\b/g, "adattabilità")
      .replace(/\bAdattabilit\b/g, "Adattabilità")
      .replace(/\bstabilit\b/g, "stabilità")
      .replace(/\bStabilit\b/g, "Stabilità")
      .replace(/\binstabilit\b/g, "instabilità")
      .replace(/\bInstabilit\b/g, "Instabilità")
      .replace(/\bvalidit\b/g, "validità")
      .replace(/\bValidit\b/g, "Validità")
      .replace(/\battivit\b/g, "attività")
      .replace(/\bAttivit\b/g, "Attività")
      .replace(/\bmodalit\b/g, "modalità")
      .replace(/\bModalit\b/g, "Modalità")
      .replace(/\bpriorit\b/g, "priorità")
      .replace(/\bPriorit\b/g, "Priorità")
      .replace(/\bsostenibilit\b/g, "sostenibilità")
      .replace(/\bSostenibilit\b/g, "Sostenibilità")
      .replace(/\bopportunit\b/g, "opportunità")
      .replace(/\bOpportunit\b/g, "Opportunità")
      .replace(/\bcriticit\b/g, "criticità")
      .replace(/\bCriticit\b/g, "Criticità")
      .replace(/\bambiguit\b/g, "ambiguità")
      .replace(/\bAmbiguit\b/g, "Ambiguità")
      .replace(/\bcentralit\b/g, "centralità")
      .replace(/\bCentralit\b/g, "Centralità")
      .replace(/\bvisibilit\b/g, "visibilità")
      .replace(/\bVisibilit\b/g, "Visibilità")
      .replace(/\bdisponibilit\b/g, "disponibilità")
      .replace(/\bDisponibilit\b/g, "Disponibilità")
      // Frasi ricorrenti dove l'AI perde il verbo essere.
      .replace(/\bIl rischio per quello\b/g, "Il rischio è quello")
      .replace(/\bIl rischio quello\b/g, "Il rischio è quello")
      .replace(/\bil rischio per quello\b/g, "il rischio è quello")
      .replace(/\bil rischio quello\b/g, "il rischio è quello")
      .replace(/\bse il cambiamento spiegato\b/g, "se il cambiamento è spiegato")
      .replace(/\bSe il cambiamento spiegato\b/g, "Se il cambiamento è spiegato")
      .replace(/\bquando il cambiamento spiegato\b/g, "quando il cambiamento è spiegato")
      .replace(/\bQuando il cambiamento spiegato\b/g, "Quando il cambiamento è spiegato")
      .replace(/\bse il contesto confuso\b/g, "se il contesto è confuso")
      .replace(/\bSe il contesto confuso\b/g, "Se il contesto è confuso")
      .replace(/\bquando il contesto confuso\b/g, "quando il contesto è confuso")
      .replace(/\bQuando il contesto confuso\b/g, "Quando il contesto è confuso")
      .replace(/\bquesto aspetto rilevante\b/g, "questo aspetto è rilevante")
      .replace(/\bQuesto aspetto rilevante\b/g, "Questo aspetto è rilevante")
      .replace(/\bil tema collegato\b/g, "il tema è collegato")
      .replace(/\bIl tema collegato\b/g, "Il tema è collegato")
      .replace(/\bL’apertura al cambiamento presente\b/g, "L’apertura al cambiamento è presente")
      .replace(/\bl’apertura al cambiamento presente\b/g, "l’apertura al cambiamento è presente")
      .replace(/\bUtile leggere questo tratto\b/g, "È utile leggere questo tratto")
      .replace(/\butile leggere questo tratto\b/g, "è utile leggere questo tratto");
  }

  function cleanDisplayList(values, separator) {
    if (!Array.isArray(values)) return cleanDisplayText(values);
    return values.map(cleanDisplayText).filter(Boolean).join(separator || ", ");
  }

  function safeText(value, fallback) {
    const cleaned = cleanDisplayText(value);
    return cleaned || fallback || "-";
  }

  const fixUtfLabel = cleanDisplayText;

  const qrCards = Array.isArray(typeof adminAssessmentCards !== "undefined" ? adminAssessmentCards : null)
    ? adminAssessmentCards
    : [{ title: "ZPI™ – Zenith Performance Index", url: assessmentUrl, qrCodeUrl, qrDownloadUrl }];
%>
  <% qrCards.forEach(function(card) { %>
    <div class="card qr-card">
      <div class="qr-preview">
        <img src="<%= card.qrCodeUrl %>" alt="QR code <%= fixUtfLabel(card.title) %>" />
      </div>
      <div>
        <h2 style="margin: 0 0 6px; font-size: 18px;">QR code <%= fixUtfLabel(card.title) %></h2>
        <p class="muted">Link diretto al questionario, utile per proiezione in sala o condivisione ai partecipanti.</p>
        <div class="link-copy"><%= card.url %></div>
        <div class="qr-actions">
          <a class="btn" href="<%= card.qrDownloadUrl %>">Scarica QR code</a>
          <a class="btn btn-secondary" href="<%= card.url %>" target="_blank">Apri questionario</a>
        </div>
      </div>
    </div>
  <% }) %>

  <div class="card">
    <form class="filters" method="GET" action="/admin">
      <div class="field">
        <label for="company">Filtra per azienda risorsa</label>
        <input
          id="company"
          type="text"
          name="company"
          placeholder="Es. Octo srl"
          value="<%= cleanDisplayText(filters && filters.company ? filters.company : '') %>"
        />
      </div>

      <div class="field">
        <label for="assessmentType">Questionario</label>
        <select id="assessmentType" name="assessmentType">
          <option value="">Tutti i questionari</option>
          <% (assessmentTypeOptions || []).forEach(function(option) { %>
            <option
              value="<%= option.key %>"
              <%= filters && filters.assessmentType === option.key ? 'selected' : '' %>
            >
              <%= fixUtfLabel(option.title) %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="field">
        <label for="fromDate">Dal</label>
        <input
          id="fromDate"
          type="date"
          name="fromDate"
          value="<%= filters && filters.fromDate ? filters.fromDate : '' %>"
        />
      </div>

      <div class="field">
        <label for="toDate">Al</label>
        <input
          id="toDate"
          type="date"
          name="toDate"
          value="<%= filters && filters.toDate ? filters.toDate : '' %>"
        />
      </div>

      <button type="submit">Filtra</button>

      <% if (filters && (filters.company || filters.assessmentType || filters.fromDate || filters.toDate)) { %>
        <a class="btn btn-secondary" href="/admin">Reset</a>
      <% } %>
    </form>

    <% if (currentAdmin && currentAdmin.role === "SUPER_ADMIN") { %>
      <form
        method="POST"
        action="/admin/regenerate-reports"
        style="margin-top: 14px;"
        onsubmit="return confirm('Rigenerare le relazioni AI per tutti gli assessment attualmente filtrati?');"
      >
        <input type="hidden" name="company" value="<%= cleanDisplayText(filters && filters.company ? filters.company : '') %>" />
        <input type="hidden" name="assessmentType" value="<%= filters && filters.assessmentType ? filters.assessmentType : '' %>" />
        <input type="hidden" name="fromDate" value="<%= filters && filters.fromDate ? filters.fromDate : '' %>" />
        <input type="hidden" name="toDate" value="<%= filters && filters.toDate ? filters.toDate : '' %>" />

        <button type="submit" class="btn btn-secondary">
          Rigenera relazioni filtrate
        </button>
      </form>


      <form
        method="POST"
        action="/admin/recalculate-scoring-v2"
        style="margin-top: 10px;"
        onsubmit="return confirm('Confermi il ricalcolo scoring V2.2 per tutti gli assessment attualmente filtrati? I punteggi verranno ricalcolati dalle risposte grezze e le relazioni AI verranno rigenerate.');"
      >
        <input type="hidden" name="company" value="<%= cleanDisplayText(filters && filters.company ? filters.company : '') %>" />
        <input type="hidden" name="assessmentType" value="<%= filters && filters.assessmentType ? filters.assessmentType : '' %>" />
        <input type="hidden" name="fromDate" value="<%= filters && filters.fromDate ? filters.fromDate : '' %>" />
        <input type="hidden" name="toDate" value="<%= filters && filters.toDate ? filters.toDate : '' %>" />
        <input type="hidden" name="regenerateAi" value="true" />

        <button type="submit" class="btn btn-secondary">
          Ricalcola scoring V2.2 + rigenera AI
        </button>
      </form>
    <% } %>
  </div>

  <% if (!submissions.length) { %>
    <div class="empty">
      <p>Nessuna compilazione presente.</p>
    </div>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Questionario</th>
          <th>Nome</th>
          <th>Email</th>
          <th>Azienda risorsa</th>
          <th>Ruolo</th>
          <th>Data</th>
          <th>Score medio</th>
          <th>Orientamento</th>
          <th>Punti forti</th>
          <th>Relazione AI</th>
          <th>Validazione</th>
          <th>Azione</th>
        </tr>
      </thead>

      <tbody>
        <% submissions.forEach(function(item) { %>
          <tr>
            <td><%= fixUtfLabel(item.assessmentTitle || "ZPI™ – Zenith Performance Index") %></td>
            <td><%= safeText(item.name) %></td>
            <td><%= safeText(item.email) %></td>
            <td><%= safeText(item.candidateCompany) %></td>
            <td><%= safeText(item.role) %></td>
            <td><%= safeText(item.createdAtFormatted || new Date(item.createdAt).toLocaleString("it-IT", { timeZone: "Europe/Rome" })) %></td>
            <td><%= item.avgScore ?? "-" %></td>
            <td><%= safeText(item.orientation) %></td>
            <td><%= item.topTraits && item.topTraits.length ? cleanDisplayList(item.topTraits, ", ") : "-" %></td>
            <td>
              <% if (item.expandedReady) { %>
                <span class="badge badge-ready">Pronta</span>
              <% } else if (item.expandedGenerating) { %>
                <span class="badge badge-pending">In generazione</span>
              <% } else if (item.generationError) { %>
                <span class="badge badge-error">Errore</span>
              <% } else { %>
                <span class="badge badge-pending">Fallback disponibile</span>
              <% } %>
            </td>
            <td>
              <% if (item.isValidated) { %>
                <span class="badge badge-ready">Validata</span>
              <% } else { %>
                <span class="badge badge-pending">Non validata</span>
              <% } %>
            </td>
            <td>
              <div class="actions">
                <a class="btn btn-secondary" href="/admin/<%= item.id %>">Apri</a>
                <a class="btn btn-secondary" href="/admin/<%= item.id %>/pdf" target="_blank">PDF</a>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</body>
</html>