<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <title>Area Admin</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      max-width: 1200px;
      margin: 40px auto;
      padding: 0 16px;
      color: #111827;
      background: #f7f9fc;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 16px;
      margin-bottom: 24px;
    }

    h1 {
      margin: 0 0 6px;
    }

    .muted {
      color: #666;
      margin: 0;
    }

    .card {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 14px;
      padding: 18px;
      margin-bottom: 18px;
    }

    .filters {
      display: flex;
      gap: 12px;
      align-items: flex-end;
      flex-wrap: wrap;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 6px;
      min-width: 260px;
    }

    label {
      font-size: 13px;
      font-weight: 700;
      color: #374151;
    }

    input {
      padding: 10px 12px;
      border: 1px solid #d1d5db;
      border-radius: 10px;
      font-size: 14px;
      background: #fff;
    }

    button,
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 10px 14px;
      border: 0;
      border-radius: 10px;
      cursor: pointer;
      text-decoration: none;
      background: #111827;
      color: #fff;
      font-size: 14px;
      font-weight: 700;
    }

    .btn-secondary {
      background: #f3f4f6;
      color: #111827;
      border: 1px solid #d1d5db;
    }

    .logout-btn {
      background: #f3f4f6;
      color: #111827;
      border: 1px solid #d1d5db;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: #fff;
      border-radius: 14px;
      overflow: hidden;
    }

    th,
    td {
      border: 1px solid #e5e7eb;
      padding: 10px;
      text-align: left;
      vertical-align: top;
      font-size: 14px;
    }

    th {
      background: #f3f4f6;
      font-size: 13px;
      color: #374151;
    }

    .badge {
      display: inline-flex;
      align-items: center;
      padding: 5px 8px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 700;
      white-space: nowrap;
    }

    .badge-ready {
      background: #dcfce7;
      color: #166534;
      border: 1px solid #bbf7d0;
    }

    .badge-pending {
      background: #fff7ed;
      color: #9a3412;
      border: 1px solid #fed7aa;
    }

    .badge-error {
      background: #fee2e2;
      color: #991b1b;
      border: 1px solid #fecaca;
    }

    .actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .empty {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 14px;
      padding: 20px;
    }

    @media (max-width: 900px) {
      body {
        margin: 24px auto;
      }

      .topbar {
        flex-direction: column;
      }

      .field {
        min-width: 100%;
      }

      .filters {
        align-items: stretch;
      }

      .filters button,
      .filters .btn {
        width: 100%;
      }

      table {
        display: block;
        overflow-x: auto;
      }
    }
  </style>
</head>

<body>
  <div class="topbar">
    <div>
      <h1>Area Admin</h1>
      <p class="muted"><%= organizationName %></p>
    </div>

    <form method="POST" action="/admin/logout">
      <button class="logout-btn" type="submit">Logout</button>
    </form>
  </div>

  <div class="card">
    <form class="filters" method="GET" action="/admin">
      <div class="field">
        <label for="company">Filtra per azienda risorsa</label>
        <input
          id="company"
          type="text"
          name="company"
          placeholder="Es. Octo srl"
          value="<%= filters && filters.company ? filters.company : '' %>"
        />
      </div>

      <button type="submit">Filtra</button>

      <% if (filters && filters.company) { %>
        <a class="btn btn-secondary" href="/admin">Reset</a>
      <% } %>
    </form>
  </div>

  <% if (!submissions.length) { %>
    <div class="empty">
      <p>Nessuna compilazione presente.</p>
    </div>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Nome</th>
          <th>Email</th>
          <th>Età</th>
          <th>Azienda risorsa</th>
          <th>Ruolo</th>
          <th>Compatibilità ruolo</th>
          <th>Data</th>
          <th>Score medio</th>
          <th>Orientamento</th>
          <th>Punti forti</th>
          <th>Relazione AI</th>
          <th>Azione</th>
        </tr>
      </thead>

      <tbody>
        <% submissions.forEach(function(item) { %>
          <tr>
            <td><%= item.name %></td>
            <td><%= item.email || "-" %></td>
            <td><%= item.age || "-" %></td>
            <td><%= item.candidateCompany || "-" %></td>
            <td><%= item.role %></td>
            <td>
              <% if (item.roleFit) { %>
                <strong><%= item.roleFit.score %>%</strong><br>
                <span class="muted"><%= item.roleFit.label %></span>
              <% } else { %>
                -
              <% } %>
            </td>
            <td><%= new Date(item.createdAt).toLocaleString("it-IT") %></td>
            <td><%= item.avgScore ?? "-" %></td>
            <td><%= item.orientation %></td>
            <td><%= item.topTraits && item.topTraits.length ? item.topTraits.join(", ") : "-" %></td>
            <td>
              <% if (item.expandedReady) { %>
                <span class="badge badge-ready">Pronta</span>
              <% } else if (item.expandedGenerating) { %>
                <span class="badge badge-pending">In generazione</span>
              <% } else if (item.generationError) { %>
                <span class="badge badge-error">Errore</span>
              <% } else { %>
                <span class="badge badge-pending">Fallback disponibile</span>
              <% } %>
            </td>
            <td>
              <div class="actions">
                <a class="btn btn-secondary" href="/admin/<%= item.id %>">Apri</a>
                <a class="btn btn-secondary" href="/admin/<%= item.id %>/pdf" target="_blank">PDF</a>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</body>
</html>