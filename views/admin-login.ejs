<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <title>Login Admin</title>
  <style>
    body { font-family: Arial, sans-serif; max-width: 460px; margin: 60px auto; padding: 0 16px; }
    .card { border: 1px solid #ddd; border-radius: 12px; padding: 24px; }
    .field { margin-bottom: 16px; }
    input { width: 100%; padding: 10px; box-sizing: border-box; }
    button { padding: 12px 18px; border: 0; border-radius: 8px; cursor: pointer; }
    .error { color: #b00020; margin-bottom: 16px; }
  </style>
</head>
<body>
  <div class="card">
    <h1>Area Admin</h1>
    <p>Accedi per visualizzare assessment, report e PDF.</p>

    <% if (error) { %>
      <p class="error"><%= error %></p>
    <% } %>

    <form method="POST" action="/admin/login">
      <div class="field">
        <label for="email">Email</label><br />
        <input id="email" name="email" type="email" required />
      </div>

      <div class="field">
        <label for="password">Password</label><br />
        <input id="password" name="password" type="password" required />
      </div>

      <button type="submit">Accedi</button>
    </form>
  </div>
</body>
</html>